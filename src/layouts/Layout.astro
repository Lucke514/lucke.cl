---
import Footer from 'shared/Footer/Footer.astro';
import Header from 'shared/Header/Header.astro';
import ScrollAnimations from 'components/ScrollAnimations.astro';
import { getLangFromUrl, useTranslations, getAlternatePath } from '../i18n/utils';

// Tipografía de la página
import '@fontsource-variable/onest';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description = t('seo.home.description'), ogImage = "/img/Avatar.webp" } = Astro.props;

const siteUrl = Astro.site?.href || 'https://lucke.cl';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const socialImageURL = new URL(ogImage, siteUrl);
const alternateES = new URL(getAlternatePath(Astro.url.pathname, 'es'), siteUrl);
const alternateEN = new URL(getAlternatePath(Astro.url.pathname, 'en'), siteUrl);

const personDescription = lang === 'es'
	? 'Software Engineer especializado en desarrollo Full Stack con Node.js, NestJS, React, Next.js y arquitecturas cloud (AWS, Azure, GCP). Más de 3 años de experiencia construyendo soluciones escalables y microservicios.'
	: 'Software Engineer specialized in Full Stack development with Node.js, NestJS, React, Next.js and cloud architectures (AWS, Azure, GCP). 3+ years of experience building scalable solutions and microservices.';

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Lucas Benjamín González Espinosa",
	"alternateName": "Lucas González",
	"jobTitle": "Full Stack Software Engineer",
	"description": personDescription,
	"url": "https://lucke.cl",
	"image": "https://lucke.cl/img/Avatar.webp",
	"email": "lucas.gonzalez.espinosa@outlook.com",
	"telephone": "+56955164337",
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Santiago",
		"addressRegion": "Región Metropolitana",
		"addressCountry": "CL"
	},
	"nationality": {
		"@type": "Country",
		"name": "Chile"
	},
	"sameAs": [
		"https://github.com/lucke514",
		"https://www.linkedin.com/in/lucas-gonzalez-espinosa"
	],
	"hasOccupation": {
		"@type": "Occupation",
		"name": "Full Stack Software Engineer",
		"occupationLocation": {
			"@type": "Country",
			"name": "Chile"
		},
		"skills": "Node.js, NestJS, React, Next.js, TypeScript, AWS, Azure, Docker, Microservices, REST API, GraphQL, PostgreSQL, MySQL, MongoDB, Prisma, CI/CD"
	},
	"hasCredential": [
		{
			"@type": "EducationalOccupationalCredential",
			"name": "Diplomado en Ciberseguridad Industrial",
			"credentialCategory": "Diploma",
			"url": "https://www.credly.com/badges/3ac42318-ba42-45d0-9832-33ad0db3af2a"
		},
		{
			"@type": "EducationalOccupationalCredential",
			"name": "CCNA: Introduction to Networks",
			"credentialCategory": "Certificate",
			"url": "https://www.credly.com/badges/13bea9eb-d2ac-469d-b491-71aa63547348"
		},
		{
			"@type": "EducationalOccupationalCredential",
			"name": "Implementador Líder Ciberseguridad CIP",
			"credentialCategory": "Certificate"
		}
	],
	"knowsAbout": [
		"Node.js", "NestJS", "React", "Next.js", "Angular", "Astro", "TypeScript",
		"JavaScript ES6+", "Amazon Web Services (AWS)", "Microsoft Azure",
		"Google Cloud Platform (GCP)", "Docker", "Microservices", "REST APIs",
		"GraphQL", "PostgreSQL", "MySQL", "MongoDB", "Redis", "Prisma ORM",
		"TypeORM", "CI/CD", "GitHub Actions", "Scrum", "Clean Architecture",
		"Hexagonal Architecture", "Cybersecurity", "DevOps"
	],
	"knowsLanguage": ["es", "en"],
	"worksFor": {
		"@type": "Organization",
		"name": "Kibernum"
	}
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Lucas González - Software Engineer",
	"alternateName": "lucke.cl",
	"url": "https://lucke.cl",
	"description": lang === 'es'
		? 'Portfolio profesional de Lucas González, Software Engineer Full Stack especializado en Node.js, React y arquitecturas cloud'
		: 'Professional portfolio of Lucas González, Full Stack Software Engineer specialized in Node.js, React and cloud architectures',
	"author": {
		"@type": "Person",
		"name": "Lucas González"
	},
	"inLanguage": lang === 'es' ? 'es-CL' : 'en-US'
};
---
<!DOCTYPE html>
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Lucas Gonzalez" />
    <meta name="keywords" content="Software Engineer Chile, Full Stack Developer Santiago, Desarrollador Node.js, NestJS Developer, React Developer, Next.js, Angular, Astro, TypeScript, JavaScript, AWS, Azure, GCP, Microservicios, Backend Developer, Cloud Architecture, DevOps, CI/CD, Docker, Kubernetes, PostgreSQL, MySQL, MongoDB, Redis, Prisma, GraphQL, REST API, Arquitectura Hexagonal, Clean Architecture, Scrum, Programador Chile, Desarrollador Web, Lucas González, lucke.cl" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#0c0a09" />

    <!-- Canonical y alternates por idioma -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={alternateES} />
    <link rel="alternate" hreflang="en" href={alternateEN} />
    <link rel="alternate" hreflang="x-default" href={alternateES} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/img/Avatar.webp" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:locale" content={lang === 'es' ? 'es_CL' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_CL'} />
    <meta property="og:site_name" content="Lucas Gonzalez - Software Engineer" />

    <!-- Twitter Card -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- CSS global -->
    <link rel="stylesheet" href="/styles/globals.css" />
 </head>
  <body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 overflow-x-hidden max-w-screen w-screen transition-colors duration-500 min-h-screen">
    <!-- Skip to main content - Accesibilidad -->
    <a href="#main-content" class="skip-link">
      {lang === 'es' ? 'Saltar al contenido principal' : 'Skip to main content'}
    </a>
    <Header />
    <main id="main-content" class="w-full relative z-10" role="main">
      <slot />
    </main>
    <Footer />
    <ScrollAnimations />
  </body>
</html>

<style is:global>
  :root {
    --accent: 239, 68, 68; /* red-500 */
    --accent-light: 252, 165, 165; /* red-300 */
    --accent-dark: 153, 27, 27; /* red-800 */
  }

  /* Skip Link - Accesibilidad */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    background: rgb(var(--accent));
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    z-index: 9999;
    font-weight: 600;
    text-decoration: none;
    transition: top 0.3s ease;
  }

  .skip-link:focus {
    top: 1rem;
    outline: 2px solid white;
    outline-offset: 2px;
  }

  ::selection {
    background-color: rgb(var(--accent));
    color: white;
  }

  html {
    font-family: 'Onest Variable', sans-serif;
    scroll-behavior: smooth;
    /* clip (no hidden): recorta los offsets pre-animación de GSAP sin
       expandir el layout viewport en móvil ni crear scroll horizontal */
    overflow-x: clip;
  }

  body {
    display: grid;
    grid-template-rows: auto 1fr auto;
    /* minmax(0,1fr): evita que el min-content de los hijos (p.ej. el slider
       de tecnologías) expanda la columna más allá del viewport en móvil */
    grid-template-columns: minmax(0, 1fr);
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: rgb(var(--accent-dark), 0.1);
  }

  ::-webkit-scrollbar-thumb {
    background: rgb(var(--accent));
    border-radius: 5px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgb(var(--accent-dark));
  }

  /* Smooth transitions for dark mode */
  .dark {
    color-scheme: dark;
  }

  /* Estado inicial de elementos animados por GSAP (evita FOUC de animación).
     Si JS no carga, el contenido sigue visible por el fallback de no-js. */
  html.js [data-animate] {
    opacity: 0;
  }

  html.js [data-animate-hero] {
    opacity: 0;
    transform: translateY(20px);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    html.js [data-animate],
    html.js [data-animate-hero] {
      opacity: 1;
      transform: none;
    }

    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>

<script is:inline>
  // Marca que JS está disponible: las animaciones de scroll solo ocultan
  // contenido cuando GSAP podrá revelarlo.
  document.documentElement.classList.add('js');
</script>
