---
import type { Project } from '../../data/projects';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  project: Project;
  lang: Lang;
  reverse?: boolean;
}

const { project, lang, reverse = false } = Astro.props;
const t = useTranslations(lang);
const hasImages = project.images.length > 0;
---

<article
  class={`relative group flex flex-col ${reverse ? 'lg:flex-row-reverse' : 'lg:flex-row'} gap-8 p-6 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 shadow-lg hover:shadow-xl hover:border-red-500/30 transform transition duration-300 hover:-translate-y-1`}
  data-animate={reverse ? 'right' : 'left'}
>
  {hasImages && (
    <figure class="lg:w-1/2 relative">
      <div class="relative aspect-video rounded-lg overflow-hidden bg-zinc-100 dark:bg-zinc-800">
        {project.images.map((image, imgIndex) => (
          <div
            class={`absolute inset-0 transition-opacity duration-500 ease-in-out
              ${imgIndex === 0 ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'}`}
          >
            <img
              src={image.src}
              alt={image.alt[lang]}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              width="640"
              height="360"
            />
          </div>
        ))}
      </div>
    </figure>
  )}

  <div class={`${hasImages ? 'lg:w-1/2' : 'w-full'} flex flex-col justify-center gap-4`}>
    <header>
      <h3 class="text-2xl font-bold text-zinc-900 dark:text-white">
        {project.title}
        {project.featured && (
          <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-950 dark:text-red-300 align-middle">
            {t('featured.badge')}
          </span>
        )}
      </h3>
    </header>

    <p class="text-zinc-600 dark:text-zinc-300 leading-relaxed">
      {project.description[lang]}
    </p>

    <ul class="flex flex-wrap gap-2">
      {project.technologies.map((tech) => (
        <li class="px-3 py-1 text-sm rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 border border-zinc-200 dark:border-zinc-700">
          {tech}
        </li>
      ))}
    </ul>

    {(project.links.github || project.links.live) && (
      <footer class="flex gap-4 pt-2">
        {project.links.github && (
          <a
            href={project.links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-zinc-900 dark:bg-zinc-800 text-white hover:bg-zinc-700 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            {t('projects.github')}
          </a>
        )}
        {project.links.live && (
          <a
            href={project.links.live}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            {t('projects.demo')}
          </a>
        )}
      </footer>
    )}
  </div>
</article>
