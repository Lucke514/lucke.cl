---
import ProjectCard from './ProjectCard.astro';
import { frontendProjects, backendProjects } from '../../data/projects';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-5xl mx-auto px-6 lg:px-10 py-16">
  <header class="space-y-4 mb-16 text-center" data-animate>
    <span class="text-red-500 font-mono text-sm tracking-wider uppercase">{t('nav.projects')}</span>
    <h1 class="text-4xl sm:text-5xl font-bold">
      {t('projectsPage.title')}
    </h1>
    <p class="text-zinc-600 dark:text-zinc-300 max-w-2xl mx-auto text-lg">
      {t('projectsPage.subtitle')}
    </p>
  </header>

  <!-- Aplicaciones web -->
  <section class="mb-20">
    <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-8 text-center" data-animate>
      {t('projectsPage.frontend')}
    </h2>

    <div class="grid gap-10">
      {frontendProjects.map((project, index) => (
        <ProjectCard project={project} lang={lang} reverse={index % 2 === 1} />
      ))}
    </div>
  </section>

  <!-- Backend y microservicios -->
  <section>
    <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-8 text-center" data-animate>
      {t('projectsPage.backend')}
    </h2>

    <div class="grid gap-6 md:grid-cols-2" data-animate-group>
      {backendProjects.map((project) => (
        <article class="flex flex-col gap-4 p-6 rounded-2xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 shadow-lg hover:shadow-xl hover:border-red-500/30 transition duration-300 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-zinc-900 dark:text-white flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
            {project.title}
          </h3>
          <p class="text-zinc-600 dark:text-zinc-300 text-sm leading-relaxed flex-1">
            {project.description[lang]}
          </p>
          <ul class="flex flex-wrap gap-2">
            {project.technologies.map((tech) => (
              <li class="px-2.5 py-1 text-xs rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 border border-zinc-200 dark:border-zinc-700">
                {tech}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <p class="text-sm text-zinc-500 dark:text-zinc-400 text-center mt-16 italic">
    {t('projectsPage.confidential')}
  </p>
</div>
