---
import ProjectCard from './ProjectCard.astro';
import { featuredProjects } from '../../data/projects';
import { useTranslations, localizePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const projectsUrl = localizePath('/proyectos', lang);
---

<section class="max-w-6xl mx-auto px-6 lg:px-10 py-24" id="projects-seccion">
  <div class="text-center mb-16" data-animate>
    <span class="text-red-500 font-mono text-sm tracking-wider uppercase">{t('featured.kicker')}</span>
    <h2 class="text-4xl sm:text-5xl font-bold mt-4 mb-6">{t('featured.title')}</h2>
    <div class="w-24 h-1 bg-red-500 mx-auto rounded-full"></div>
  </div>

  <div class="grid gap-10">
    {featuredProjects.map((project, index) => (
      <ProjectCard project={project} lang={lang} reverse={index % 2 === 1} />
    ))}
  </div>

  <div class="text-center mt-12" data-animate>
    <a
      href={projectsUrl}
      class="inline-flex items-center gap-2 px-8 py-4 border-2 border-red-500 text-red-600 dark:text-red-400 rounded-lg font-semibold hover:bg-red-500 hover:text-white dark:hover:text-white transition-all duration-300 hover:-translate-y-1"
    >
      {t('featured.viewAll')}
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
