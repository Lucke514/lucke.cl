---
import Layout from '../../layouts/Layout.astro';
import Hero from 'components/sections/Hero.astro';
import About from 'components/sections/About.astro';
import FeaturedProjects from 'components/sections/FeaturedProjects.astro';
import ExperienceSection from 'components/sections/ExperienceSection.astro';
import TechSection from 'components/sections/TechSection.astro';
import CertsSection from 'components/sections/CertsSection.astro';
import Contact from 'components/sections/Contact.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={t('seo.home.title')} description={t('seo.home.description')}>
  <Hero lang={lang} />
  <About lang={lang} />
  <FeaturedProjects lang={lang} />
  <ExperienceSection lang={lang} />
  <TechSection lang={lang} />
  <CertsSection lang={lang} />
  <Contact lang={lang} />
</Layout>
