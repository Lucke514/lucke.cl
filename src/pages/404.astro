---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations, localizePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('seo.notFound.title')}>
    <div class="min-h-[70vh] flex items-center justify-center px-4">
        <div class="text-center max-w-md mx-auto">
            <!-- Avatar -->
            <div class="mb-8">
                <img
                    src="/img/Avatar.webp"
                    alt="Avatar Lucas González"
                    class="w-24 h-24 md:w-32 md:h-32 rounded-full mx-auto shadow-lg"
                    loading="lazy"
                    width="128"
                    height="128"
                />
            </div>

            <h1 class="text-6xl md:text-8xl font-bold text-zinc-900 dark:text-white mb-4">
                404
            </h1>

            <h2 class="text-2xl md:text-3xl font-semibold text-zinc-700 dark:text-zinc-300 mb-4">
                {t('notFound.title')}
            </h2>

            <p class="text-zinc-600 dark:text-zinc-400 mb-8 leading-relaxed">
                {t('notFound.text')}
                {t('notFound.redirect')} <span id="countdown" class="font-bold text-red-600 dark:text-red-400">5</span> {t('notFound.seconds')}.
            </p>

            <div class="space-y-4">
                <a
                    href={localizePath('/', lang)}
                    class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-red-600 text-white hover:bg-red-700 font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    {t('notFound.home')}
                </a>

                <div class="flex justify-center space-x-4 text-sm">
                    <a
                        href={localizePath('/proyectos', lang)}
                        class="text-zinc-600 dark:text-zinc-400 hover:text-red-600 dark:hover:text-red-400 transition-colors"
                    >
                        {t('notFound.projects')}
                    </a>
                    <span class="text-zinc-400">•</span>
                    <a
                        href={`${localizePath('/', lang)}#about-seccion`}
                        class="text-zinc-600 dark:text-zinc-400 hover:text-red-600 dark:hover:text-red-400 transition-colors"
                    >
                        {t('notFound.about')}
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>

<!-- Script para redirección automática -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        let countdown = 5;
        const countdownElement = document.getElementById('countdown');

        const timer = setInterval(() => {
            countdown--;
            if (countdownElement) {
                countdownElement.textContent = countdown.toString();
            }

            if (countdown <= 0) {
                clearInterval(timer);
                window.location.href = '/';
            }
        }, 1000);

        // Pausar countdown si el usuario interactúa con la página
        document.addEventListener('click', () => {
            clearInterval(timer);
            if (countdownElement) {
                countdownElement.textContent = '∞';
            }
        });
    });
</script>
